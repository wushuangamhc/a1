{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "types": [
      "@moddota/dota-lua-types"
    ],
    "outDir": "game/A1/scripts/vscripts",
    "lib": [
      "ESNext"
    ],
    "strictPropertyInitialization": false
  },
  "include": [
    "src/vscripts/**/*.ts",
    "shared/**/*.ts",
    "node_modules/@moddota/dota-lua-types/index.d.ts"
  ],
  "tstl": {
    "luaTarget": "5.1",
    "luaLibImport": "inline",
    "noHeader": false
  }
}
