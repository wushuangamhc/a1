{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "types": [
      "@moddota/dota-lua-types"
    ],
    "rootDir": ".",
    "outDir": "addon/game/scripts/vscripts",
    "lib": [
      "ESNext"
    ]
  },
  "include": [
    "game/**/*.ts",
    "shared/**/*.ts",
    "node_modules/@moddota/dota-lua-types/normalized.d.ts"
  ],
  "tstl": {
    "luaTarget": "5.1",
    "luaLibImport": "none",
    "noHeader": false
  }
}
